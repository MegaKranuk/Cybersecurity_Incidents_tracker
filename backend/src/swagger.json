{
  "openapi": "3.0.0",
  "info": {
    "title": "Cybersecurity Incident Tracker API",
    "version": "1.0.0",
    "description": "Документація API для лабораторної роботи №2 (Андрій Нижник)"
  },
  "servers": [{ "url": "http://localhost:3000" }],
  "paths": {
    "/api/incidents": {
      "get": {
        "summary": "Отримати список інцидентів",
        "parameters": [
          { "name": "tag", "in": "query", "schema": { "type": "string" }, "description": "Фільтр за типом" },
          { "name": "sortBy", "in": "query", "schema": { "type": "string" }, "description": "Сортування (напр. date)" },
          { "name": "Criticality", "in": "query", "schema": { "type": "string"}, "description": "Фільтр за критичністю" },
          { "name": "sortDir", "in": "query", "schema": { "type": "string", "enum":["asc", "desc"] }, "description": "Напрямок сортування" },
          { "name": "page", "in": "query", "schema": { "type": "string", "default": "1" }, "description": "Номер сторінки" },
          { "name": "pageSize", "in": "query", "schema": { "type": "string", "default": "1" }, "description": "К-сть елементів на сторінці" }
        ],
        "responses": 
        { "200": 
          { "description": "Успіх",
            "content":
            {
            "application/json":
              {
                "schema":
                {
                  "type":"object",
                  "properties":
                  {
                    "items": {"type": "array", "items": {"type": "object"}},
                    "meta": 
                    {
                      "type":"object",
                      "properties":{
                        "totalItems": {"type": "number", "example": 15},
                        "currentPage": {"type": "number", "example": 1},
                        "pageSize": {"type": "number", "example": 10},
                        "totalPage": {"type": "number", "example": 2}
                      }
                    }
                  }
                }
              }
            } 
          } 
        }
      },
      "post": {
        "summary": "Створити новий інцидент",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "date": { "type": "string", "example": "2026-03-03" },
                  "tag": { "type": "string" },
                  "criticality": { "type": "string" },
                  "reporter": { "type": "string" },
                  "comment": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Створено" }, "400": { "description": "Помилка валідації" } }
      }
    }
  }
}